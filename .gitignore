# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Trashes
._*

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Python cache / build artifacts
__pycache__/
*.py[cod]
build/
dist/
.eggs/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/
.conda/
conda-meta/
.python-version
.uv/

# Jupyter
.ipynb_checkpoints/

# Logs / local temp files
*.log
logs/
tmp/
temp/
.cache/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Environment / secrets
.env
.env.local
.env.*.local
*.env
*.local
*.secret
secrets.*
credentials.*
token.*
tokens.*
apikey.*
api_key.*
*.pem
*.key
*.crt
*.p12
*.pfx

# Allow safe templates
!.env.example
!.env.sample
!.env.template

# Allow screenshots folder, but disallow images within it
screenshots/*
!screenshots/.gitkeep
!screenshots/diff/.gitkeep
